# Copy to .env and fill in from Firebase Console → Project settings → Your apps
# Set to false to skip login and Firebase auth (local dev). Pair with AUTH_ENABLED=false on the API.
# VITE_AUTH_ENABLED=false
#
# TestSprite / E2E without login: use committed `.env.testsprite` via `npm run dev:testsprite`
# (from this folder). See AUTH_RECOVERY_PROMPT.txt to turn real auth back on.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_API_BASE=http://localhost:3001/api
