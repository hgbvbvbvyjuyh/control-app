# Copy to .env — do not commit .env
# Set to false to skip Bearer token checks (local dev). Use with VITE_AUTH_ENABLED=false on the frontend.
# AUTH_ENABLED=false
# Optional stable user id when auth is disabled (defaults to dev-local-user)
# DEV_AUTH_USER_ID=dev-local-user
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# PEM with \n for newlines, e.g. "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

PORT=3001
DB_PATH=./productivity.db
